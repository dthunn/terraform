.env

# Local .terraform directory (plugins/modules cache)
.terraform/

# State files - can contain sensitive data
*.tfstate
*.tfstate.backup

# Var files that may contain secrets
*.tfvars
*.tfvars.json

# Plan output files - can contain secrets
*.tfplan
*.plan

# Override files (local-only overrides)
override.tf
override.tf.json
*_override.tf
*_override.tf.json
